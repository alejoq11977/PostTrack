# Copy this file to .env (backend/src/.env) and fill in the values.
# .env is gitignored; never commit real secrets.

# --- Core ---
SECRET_KEY=change-me
DEBUG=True
# DATABASE_URL=sqlite:///db.sqlite3

# --- Frontend base URL (used to build links inside emails) ---
FRONTEND_URL=http://localhost:5173

# --- ImgBB (visual evidence uploads) ---
IMGBB_API_KEY=

# --- Email via Brevo SMTP ---
# In Brevo: SMTP & API -> SMTP tab. Login = the smtp-brevo.com address, password = the SMTP key (xsmtpsib-...).
# BREVO_SENDER_EMAIL must be a verified sender (Brevo -> Senders).
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=PostTrack
# Optional overrides (defaults are correct for Brevo):
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
